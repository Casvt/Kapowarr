{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Format All",
            "type": "shell",
            "command": "python3 -m isort .; python3 -m autopep8 --in-place -r .",
            "windows": {
                "command": "python -m isort .; python -m autopep8 --in-place -r ."
            },
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "clear": true
            }
        },
        {
            "label": "Create Memory Profile Data",
            "hide": true,
            "type": "shell",
            "command": "memray flamegraph -f ${workspaceFolder}/mem_prof.bin -o ${workspaceFolder}/mem_prof.html && rm ${workspaceFolder}/mem_prof.bin",
            "group": "none",
            "presentation": {
                "reveal": "silent",
                "clear": true
            }
        },
        {
            "label": "Show Profile Data",
            "hide": true,
            "type": "shell",
            "command": "snakeviz ${workspaceFolder}/stats.prof && rm ${workspaceFolder}/stats.prof",
            "group": "none",
            "presentation": {
                "reveal": "always",
                "clear": true
            }
        }
    ]
}